SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgresql://scancourse:scancourse@localhost:5432/scancourse
REDIS_URL=redis://localhost:6379/0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Google Gemini (AI assistant + motivation letters)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# Google Cloud Vision API (OCR of report cards) — get a key at
# https://console.cloud.google.com → APIs & Services → Credentials → "Create API key"
# then enable the "Cloud Vision API" for your project.
GOOGLE_CLOUD_API_KEY=AIza...
# Optional alternative for production: path to a service-account JSON.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_VALIDATE_SIGNATURE=False

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=dev-master-key-change-in-prod

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firebase (for push notifications)
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-credentials.json

# AWS S3 (for media storage in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=scancourse-media
AWS_S3_REGION_NAME=af-south-1

# Tesseract
TESSERACT_CMD=/usr/bin/tesseract

# Sentry (production)
SENTRY_DSN=

# Email (production)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@scancourse.co.za
